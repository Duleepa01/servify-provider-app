<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1E">

    <LinearLayout
        android:id="@+id/layoutHero"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="56dp"
        android:background="@drawable/bg_provider_register_header">

        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_icon_badge"
            android:layout_marginBottom="18dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_handyman"
                app:tint="@android:color/white"
                android:contentDescription="@null" />

        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/provider_register_hero_tag"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.18"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/provider_register_hero_title"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:lineSpacingMultiplier="1.1" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="270dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="36dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#1A1A2E">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="40dp">

                    <View
                        android:id="@+id/viewHandle"
                        android:layout_width="44dp"
                        android:layout_height="5dp"
                        android:background="@drawable/bg_handle_dark"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- ── Personal Information ── -->

                    <TextView
                        android:id="@+id/tvSectionPersonal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:text="@string/provider_register_section_personal"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF82"
                        android:letterSpacing="0.1"
                        app:layout_constraintTop_toBottomOf="@id/viewHandle"
                        app:layout_constraintStart_toStartOf="parent" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilName"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/provider_register_hint_name"
                        app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                        app:startIconTint="#4CAF82"
                        app:boxStrokeColor="#1F5C3A"
                        app:boxBackgroundColor="#1E2D26"
                        app:hintTextColor="#4CAF82"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tvSectionPersonal"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#6B6B8A"
                            android:backgroundTint="@android:color/transparent"
                            android:inputType="textPersonName|textCapWords"
                            android:imeOptions="actionNext"
                            android:maxLines="1" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilEmail"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/provider_register_hint_email"
                        app:startIconDrawable="@android:drawable/ic_dialog_email"
                        app:startIconTint="#4CAF82"
                        app:boxStrokeColor="#1F5C3A"
                        app:boxBackgroundColor="#1E2D26"
                        app:hintTextColor="#4CAF82"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tilName"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#6B6B8A"
                            android:backgroundTint="@android:color/transparent"
                            android:inputType="textEmailAddress"
                            android:imeOptions="actionNext"
                            android:maxLines="1" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPhone"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/provider_register_hint_phone"
                        app:startIconDrawable="@android:drawable/ic_menu_call"
                        app:startIconTint="#4CAF82"
                        app:boxStrokeColor="#1F5C3A"
                        app:boxBackgroundColor="#1E2D26"
                        app:hintTextColor="#4CAF82"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tilEmail"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#6B6B8A"
                            android:backgroundTint="@android:color/transparent"
                            android:inputType="phone"
                            android:imeOptions="actionNext"
                            android:maxLines="1" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- ── Service Details ── -->

                    <TextView
                        android:id="@+id/tvSectionService"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:text="@string/provider_register_section_service"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF82"
                        android:letterSpacing="0.1"
                        app:layout_constraintTop_toBottomOf="@id/tilPhone"
                        app:layout_constraintStart_toStartOf="parent" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilServiceCategory"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/provider_register_hint_category"
                        app:startIconDrawable="@drawable/ic_category"
                        app:startIconTint="#4CAF82"
                        app:boxStrokeColor="#1F5C3A"
                        app:boxBackgroundColor="#1E2D26"
                        app:hintTextColor="#4CAF82"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tvSectionService"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <AutoCompleteTextView
                            android:id="@+id/actvServiceCategory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#6B6B8A"
                            android:backgroundTint="@android:color/transparent"
                            android:inputType="none"
                            android:maxLines="1" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- ── Location ── -->

                    <TextView
                        android:id="@+id/tvSectionLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:text="@string/provider_register_section_location"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF82"
                        android:letterSpacing="0.1"
                        app:layout_constraintTop_toBottomOf="@id/tilServiceCategory"
                        app:layout_constraintStart_toStartOf="parent" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilServiceArea"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/provider_register_hint_service_area"
                        app:startIconDrawable="@android:drawable/ic_menu_mylocation"
                        app:startIconTint="#4CAF82"
                        app:boxStrokeColor="#1F5C3A"
                        app:boxBackgroundColor="#1E2D26"
                        app:hintTextColor="#4CAF82"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tvSectionLocation"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextServiceArea"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#6B6B8A"
                            android:backgroundTint="@android:color/transparent"
                            android:inputType="textPostalAddress|textCapWords"
                            android:imeOptions="actionNext"
                            android:maxLines="1" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- ── Account Security ── -->

                    <TextView
                        android:id="@+id/tvSectionSecurity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:text="@string/provider_register_section_security"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF82"
                        android:letterSpacing="0.1"
                        app:layout_constraintTop_toBottomOf="@id/tilServiceArea"
                        app:layout_constraintStart_toStartOf="parent" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPassword"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/provider_register_hint_password"
                        app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                        app:startIconTint="#4CAF82"
                        app:boxStrokeColor="#1F5C3A"
                        app:boxBackgroundColor="#1E2D26"
                        app:hintTextColor="#4CAF82"
                        app:endIconMode="password_toggle"
                        app:endIconTint="#4CAF82"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tvSectionSecurity"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#6B6B8A"
                            android:backgroundTint="@android:color/transparent"
                            android:inputType="textPassword"
                            android:imeOptions="actionDone"
                            android:maxLines="1" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Register button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonRegister"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginTop="28dp"
                        android:text="@string/provider_register_btn"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:letterSpacing="0.04"
                        app:backgroundTint="#1A6B4A"
                        app:cornerRadius="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tilPassword"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:indeterminateTint="#4CAF82"
                        android:visibility="gone"
                        app:layout_constraintTop_toBottomOf="@id/buttonRegister"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- Divider -->
                    <View
                        android:id="@+id/dividerLeft"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="24dp"
                        android:background="#1E3D2A"
                        app:layout_constraintTop_toBottomOf="@id/progressBar"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/tvDivider" />

                    <TextView
                        android:id="@+id/tvDivider"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="@string/provider_register_divider"
                        android:textSize="12sp"
                        android:textColor="#6B6B8A"
                        app:layout_constraintTop_toTopOf="@id/dividerLeft"
                        app:layout_constraintBottom_toBottomOf="@id/dividerLeft"
                        app:layout_constraintStart_toEndOf="@id/dividerLeft"
                        app:layout_constraintEnd_toStartOf="@id/dividerRight" />

                    <View
                        android:id="@+id/dividerRight"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:background="#1E3D2A"
                        app:layout_constraintTop_toTopOf="@id/dividerLeft"
                        app:layout_constraintBottom_toBottomOf="@id/dividerLeft"
                        app:layout_constraintStart_toEndOf="@id/tvDivider"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/textLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:text="@string/provider_register_login_prompt"
                        android:textColor="#4CAF82"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"
                        app:layout_constraintTop_toBottomOf="@id/dividerLeft"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>